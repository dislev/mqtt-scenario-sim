{
  "name": "mqtt-scenario-sim",
  "version": "1.0.0",
  "description": "Configurable MQTT sensor simulator with built-in test scenarios. Publish synthetic sensor data over MQTT — as JSON or protobuf — without real hardware.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mqtt-scenario-sim": "dist/cli.js"
  },
  "files": [
    "dist/",
    "examples/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "test": "c8 mocha",
    "lint": "eslint src test"
  },
  "keywords": [
    "mqtt",
    "iot",
    "sensor",
    "simulator",
    "testing",
    "mock",
    "scenario",
    "protobuf"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "express": "^5.2.1",
    "js-yaml": "^4.1.0",
    "mqtt": "^5.15.1",
    "protobufjs": "^8.3.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.0.0",
    "@types/sinon": "^17.0.4",
    "c8": "^10.1.3",
    "chai": "^5.2.0",
    "eslint": "^9.0.0",
    "mocha": "^12.0.0-beta-9.4",
    "sinon": "^22.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
