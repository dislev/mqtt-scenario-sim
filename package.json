{
  "name": "mqtt-scenario-sim",
  "version": "1.0.0",
  "description": "Configurable MQTT sensor simulator with built-in test scenarios. Publish synthetic sensor data over MQTT — as JSON or protobuf — without real hardware.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mqtt-scenario-sim": "dist/cli.js"
  },
  "files": [
    "dist/",
    "examples/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "test": "c8 mocha",
    "test:ci": "c8 --reporter=lcov --reporter=text mocha",
    "lint": "eslint src test"
  },
  "keywords": [
    "mqtt",
    "iot",
    "sensor",
    "simulator",
    "testing",
    "mock",
    "scenario",
    "protobuf"
  ],
  "license": "MIT",
  "author": "dislev",
  "repository": {
    "type": "git",
    "url": "https://github.com/dislev/mqtt-scenario-sim.git"
  },
  "homepage": "https://github.com/dislev/mqtt-scenario-sim#readme",
  "bugs": {
    "url": "https://github.com/dislev/mqtt-scenario-sim/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "express": "^5.2.1",
    "js-yaml": "^4.1.0",
    "mqtt": "^5.15.1",
    "protobufjs": "^8.3.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.8.0",
    "c8": "^10.1.3",
    "chai": "^6.2.2",
    "eslint": "^10.4.0",
    "mocha": "^12.0.0-beta-10",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3"
  }
}
