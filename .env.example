# MQTT broker
MQTT_HOST=localhost
MQTT_PORT=1883

# Publish interval in milliseconds
PUBLISH_INTERVAL_MS=5000

# Encoding: json | protobuf
ENCODING=json

# Protobuf (required when ENCODING=protobuf)
# PROTO_FILE=./my.proto
# PROTO_MESSAGE_TYPE=myapp.SensorReading
# PROTO_FIELD_MAP={"metric":"sensor_name","value":"reading_value","timestamp":"recorded_at"}

# Config file path
CONFIG_PATH=examples/minimal.yaml

# HTTP control plane port
PORT=4000

# Log level: silent | error | warn | info | debug
LOG_LEVEL=info
